# ── Local development ──────────────────────────────────────────────────────────
# DATABASE_URL and REDIS_URL are used directly in dev (docker compose up for local DB/Redis)
DATABASE_URL=postgresql://nap:nap_dev_password@localhost:5432/nap_db
REDIS_URL=redis://localhost:6379

# ── Docker Compose / Coolify ────────────────────────────────────────────────────
# In production docker-compose the DATABASE_URL is built from these:
POSTGRES_USER=nap
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=nap_db

# ── API ─────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Set to 'true' when using an external managed DB with SSL (Neon, Supabase, RDS)
DATABASE_SSL=false

# Required in production — set to your frontend domain
CORS_ORIGIN=https://yourdomain.com

# Exposed port for the web service (default 80)
WEB_PORT=80
